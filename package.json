{
  "name": "react-fabric",
  "version": "0.0.0",
  "description": "React UI Framework",
  "author": "Adarsh Pastakia <adarshpastakia@outlook.com>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "makelink": "lerna run makelink",
    "removelink": "lerna run removelink",
    "bootstrap": "lerna bootstrap",
    "prebuild": "yarn copy:arcgis && jest --ci --runInBand --detectOpenHandles --json --outputFile=./.storybook/jest-test-results.json",
    "storybook": "storybook dev -p 6003",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 storybook build -o ./build",
    "tailwind:build": "@tailwindcss/cli --cwd ./.storybook/styles -i ./styles.css -o ./build.css",
    "tailwind:watch": "yarn tailwind:build --watch",
    "lint:css": "stylelint packages/**/*.css",
    "lint:ts": "eslint --no-error-on-unmatched-pattern .",
    "check:ts": "lerna run build:dts --stream",
    "lint": "npm-run-all lint:css lint:ts check:ts",
    "copy:arcgis": "cp -r ./node_modules/@arcgis/core/assets/ ./assets/@arcgis",
    "pretest": "npm run lint",
    "jest": "jest --ci --runInBand --detectOpenHandles --forceExit --coverage",
    "test": "npm run jest",
    "dist": "lerna run build",
    "watch": "lerna run watch --parallel",
    "release": "lerna version --conventional-commits --yes --preid=beta -m \"chore(release): %v\""
  },
  "resolutions": {
    "@lexical/clipboard": "0.41.0",
    "@lexical/link": "0.41.0",
    "@lexical/list": "0.41.0",
    "@lexical/markdown": "0.41.0",
    "@lexical/plain-text": "0.41.0",
    "@lexical/react": "0.41.0",
    "@lexical/rich-text": "0.41.0",
    "@lexical/selection": "0.41.0",
    "@lexical/utils": "0.41.0",
    "jackspeak": "2.1.1",
    "lexical": "0.41.0"
  },
  "dependencies": {
    "i18next": "~25.8.18",
    "i18next-browser-languagedetector": "~8.2.1",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "react-i18next": "~16.5.8",
    "react-router": "~7.13.1",
    "react-router-dom": "~7.13.1",
    "resize-observer-polyfill": "~1.5.1"
  },
